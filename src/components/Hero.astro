---
// Hero Section: Main landing area with headline, subline, and animated terminal
---

<section class="hero min-h-screen flex items-center justify-center relative overflow-hidden pt-20 pb-20">
  <!-- Background gradient effect -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-green-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-1/4 w-96 h-96 bg-green-500/3 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-8">
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-4">
            Generate QR Codes at the <span class="neon-text">Speed of Rust</span>
          </h1>
          <p class="text-lg sm:text-xl text-gray-400 leading-relaxed">
            Blazing-fast CLI tool. PNG & SVG output. Zero dependencies. Built by a solo developer who cares about performance.
          </p>
        </div>

        <!-- Terminal Window -->
        <div class="terminal-window">
          <div class="terminal-header">
            <div class="terminal-buttons">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <span class="text-xs text-gray-500">qr-generator</span>
          </div>
          <div class="terminal-body">
            <div class="text-green-400 font-mono text-sm">
              <span class="text-gray-500">$</span> cargo run -- --text "https://yourlink.com" --output qr.png
            </div>
            <div class="typing-animation mt-2">
              <span class="text-green-400 font-mono text-sm">
                <span class="text-gray-500">→</span> Compiling qr-generator v1.0.0
              </span>
            </div>
            <div class="typing-animation mt-1" style="animation-delay: 0.5s">
              <span class="text-green-400 font-mono text-sm">
                <span class="text-gray-500">→</span> Finished release [optimized] target(s) in 0.42s
              </span>
            </div>
            <div class="typing-animation mt-1" style="animation-delay: 1s">
              <span class="text-green-400 font-mono text-sm">
                <span class="text-gray-500">→</span> QR code generated: qr.png ✓
              </span>
            </div>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a 
            href="https://github.com/hemil-59s/qr-generator" 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3 border-2 border-green-500 text-green-400 font-semibold rounded-lg hover:bg-green-500/10 hover:shadow-lg hover:shadow-green-500/50 transition-all duration-300 group"
          >
            <span class="text-xl mr-2">⭐</span>
            <span>Star on GitHub</span>
          </a>
          <a 
            href="#features" 
            class="inline-flex items-center justify-center px-8 py-3 bg-green-500/10 border-2 border-green-500/30 text-green-400 font-semibold rounded-lg hover:bg-green-500/20 hover:border-green-500 transition-all duration-300"
          >
            <span class="text-xl mr-2">📥</span>
            <span>View Docs</span>
          </a>
        </div>
      </div>

      <!-- Right: Glowing QR Code -->
      <div class="flex justify-center items-center">
        <div class="relative w-64 h-64 sm:w-80 sm:h-80">
          <!-- Outer glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-green-500/20 to-transparent rounded-2xl blur-3xl animate-pulse"></div>
          
          <!-- QR Code Container -->
          <div class="relative w-full h-full bg-white rounded-2xl p-6 shadow-2xl" style="box-shadow: 0 0 40px rgba(34, 197, 94, 0.6), inset 0 0 20px rgba(34, 197, 94, 0.1);">
            <!-- Scanline effect -->
            <div class="absolute inset-0 rounded-2xl overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-b from-transparent via-green-500/10 to-transparent animate-scanline"></div>
            </div>
            
            <!-- QR Code SVG -->
            <svg viewBox="0 0 200 200" class="w-full h-full relative z-10" xmlns="http://www.w3.org/2000/svg">
              <!-- QR Code pattern (simplified representation) -->
              <rect width="200" height="200" fill="white"/>
              
              <!-- Position markers (corners) -->
              <g fill="black">
                <!-- Top-left -->
                <rect x="10" y="10" width="50" height="50"/>
                <rect x="15" y="15" width="40" height="40" fill="white"/>
                <rect x="20" y="20" width="30" height="30" fill="black"/>
                
                <!-- Top-right -->
                <rect x="140" y="10" width="50" height="50"/>
                <rect x="145" y="15" width="40" height="40" fill="white"/>
                <rect x="150" y="20" width="30" height="30" fill="black"/>
                
                <!-- Bottom-left -->
                <rect x="10" y="140" width="50" height="50"/>
                <rect x="15" y="145" width="40" height="40" fill="white"/>
                <rect x="20" y="150" width="30" height="30" fill="black"/>
              </g>
              
              <!-- Data pattern (random-looking but symmetric) -->
              <g fill="black" opacity="0.8">
                <rect x="70" y="70" width="60" height="60"/>
                <rect x="75" y="75" width="50" height="50" fill="white"/>
                <rect x="80" y="80" width="40" height="40" fill="black"/>
                <rect x="85" y="85" width="30" height="30" fill="white"/>
                <rect x="90" y="90" width="20" height="20" fill="black"/>
              </g>
              
              <!-- Additional data modules -->
              <g fill="black" opacity="0.7">
                <rect x="65" y="30" width="8" height="8"/>
                <rect x="65" y="45" width="8" height="8"/>
                <rect x="80" y="30" width="8" height="8"/>
                <rect x="100" y="30" width="8" height="8"/>
                <rect x="120" y="30" width="8" height="8"/>
                
                <rect x="30" y="65" width="8" height="8"/>
                <rect x="45" y="65" width="8" height="8"/>
                <rect x="30" y="80" width="8" height="8"/>
                <rect x="45" y="80" width="8" height="8"/>
              </g>
            </svg>
          </div>

          <!-- Border pulse animation -->
          <div class="absolute inset-0 rounded-2xl border-2 border-green-500/50 animate-pulse-border"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .terminal-window {
    background-color: #0f0f0f;
    border: 1px solid #1a1a1a;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.2);
  }

  .terminal-header {
    background-color: #1a1a1a;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid #2a2a2a;
  }

  .terminal-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .typing-animation {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
  }

  @keyframes animate-scanline {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }

  .animate-scanline {
    animation: animate-scanline 3s linear infinite;
  }

  @keyframes animate-pulse-border {
    0%, 100% {
      box-shadow: 0 0 20px rgba(34, 197, 94, 0.5), inset 0 0 20px rgba(34, 197, 94, 0.1);
    }
    50% {
      box-shadow: 0 0 40px rgba(34, 197, 94, 0.8), inset 0 0 30px rgba(34, 197, 94, 0.2);
    }
  }

  .animate-pulse-border {
    animation: animate-pulse-border 2s ease-in-out infinite;
  }
</style>
