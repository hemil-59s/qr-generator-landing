---
// Footer Section: Credits, links, and license
---

<footer class="footer py-16 sm:py-20 border-t border-green-500/20 relative overflow-hidden">
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/2 right-1/4 w-96 h-96 bg-green-500/3 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- About -->
      <div>
        <h3 class="text-lg font-bold mb-4 neon-text">QR Generator</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          A blazing-fast CLI tool for generating QR codes. Built with Rust by a solo developer who believes in performance and simplicity.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-lg font-bold mb-4">Links</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://github.com/hemil-59s/qr-generator" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-green-400 transition-colors text-sm">
              → GitHub Repository
            </a>
          </li>
          <li>
            <a href="https://github.com/hemil-59s/qr-generator/blob/main/README.md" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-green-400 transition-colors text-sm">
              → Documentation
            </a>
          </li>
          <li>
            <a href="https://github.com/hemil-59s/qr-generator/issues" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-green-400 transition-colors text-sm">
              → Report Issues
            </a>
          </li>
        </ul>
      </div>

      <!-- License -->
      <div>
        <h3 class="text-lg font-bold mb-4">License</h3>
        <p class="text-gray-400 text-sm mb-3">
          This project is open source and available under the MIT License.
        </p>
        <a href="https://github.com/hemil-59s/qr-generator/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="inline-block px-4 py-2 border border-green-500/30 text-green-400 text-sm rounded hover:border-green-500 hover:bg-green-500/10 transition-all">
          View License
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-green-500/30 to-transparent my-12"></div>

    <!-- Bottom Section -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>
        Built with <span class="text-red-500">❤️</span> and <span class="neon-text">Rust 🦀</span> by <a href="https://github.com/hemil-59s" target="_blank" rel="noopener noreferrer" class="text-green-400 hover:text-green-300 transition-colors">hemil-59s</a>
      </p>
      <p>
        © 2024 QR Generator. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(34, 197, 94, 0.02) 100%);
  }
</style>
